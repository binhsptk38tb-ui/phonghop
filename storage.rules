rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /meetings/{meetingId}/documents/{fileName} {
      // Allow read access to authenticated users
      allow read: if request.auth != null;
      
      // Allow write access if user is authenticated
      // In a more production environment, you might check roles via Firestore
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024; // Limit 10MB
      
      // Allow delete if authenticated
      allow delete: if request.auth != null;
    }
  }
}
