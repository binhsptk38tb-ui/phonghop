rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isManagement() {
      return hasRole('management') || isAdmin();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role']) &&
             data.role in ['admin', 'management', 'teacher', 'staff'];
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['title', 'scheduledAt', 'status', 'createdBy']);
    }

    // Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid == userId // Allow self-registration
      );
      allow update: if (isAdmin() && isValidUser(request.resource.data)) || 
                   (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']));
    }

    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow create: if isManagement() && isValidMeeting(request.resource.data);
      allow update: if isManagement() && isValidMeeting(request.resource.data);
      allow delete: if isAdmin();

      match /attendance/{userId} {
        allow read: if isSignedIn();
        allow write: if isManagement() || isOwner(userId);
      }

      match /opinions/{opinionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
      }

      match /tasks/{taskId} {
        allow read: if isSignedIn();
        allow write: if isManagement();
      }

      match /documents/{docId} {
        allow read: if isSignedIn();
        allow create: if isManagement();
        allow delete: if isManagement();
      }
    }
  }
}
