rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Master Admin Global Bypass
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == 'binhsptk38tb@gmail.com';
    }

    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Default deny for others
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasPosition(pos) {
      return isSignedIn() && getUserData().get('position', 'staff') == pos;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().get('role', 'member') == role;
    }

    function isAdmin() {
      return hasPosition('admin') || isMasterAdmin();
    }

    function isManagement() {
      return hasPosition('principal') || hasPosition('vice_principal') || isAdmin();
    }

    function isMeetingManager() {
      return hasRole('chairperson') || hasRole('secretary') || isMasterAdmin();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Validations
    function isValidUser(data) {
      return data.get('position', 'staff') in ['admin', 'principal', 'vice_principal', 'teacher', 'staff'] &&
             data.get('role', 'member') in ['chairperson', 'secretary', 'member'];
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['title', 'scheduledAt', 'status', 'createdBy']);
    }

    // Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid == userId // Allow self-registration
      );
      allow update: if isAdmin() || 
                   (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phoneNumber']));
      allow delete: if isAdmin();
    }

    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow create: if isMeetingManager() && isValidMeeting(request.resource.data);
      allow update: if isMeetingManager() && isValidMeeting(request.resource.data);
      allow delete: if isMeetingManager();

      match /attendance/{userId} {
        allow read: if isSignedIn();
        allow write: if isManagement() || isOwner(userId);
      }

      match /opinions/{opinionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
      }

      match /tasks/{taskId} {
        allow read: if isSignedIn();
        allow write: if isManagement();
      }

      match /documents/{docId} {
        allow read: if isSignedIn();
        allow create: if isManagement();
        allow delete: if isManagement();
      }
    }
  }
}
