rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Master Admin Global Bypass
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == 'binhsptk38tb@gmail.com';
    }

    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Default deny for others
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : (exists(/databases/$(database)/documents/users/$(request.auth.token.email))
          ? get(/databases/$(database)/documents/users/$(request.auth.token.email)).data
          : {});
    }

    function hasPosition(pos) {
      return isSignedIn() && getUserData().get('position', 'staff') == pos;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().get('role', 'member') == role;
    }

    function isAdmin() {
      return hasPosition('admin') || isMasterAdmin();
    }

    function isManagement() {
      let pos = getUserData().get('position', 'staff');
      return pos == 'principal' || pos == 'vice_principal' || pos == 'admin' || isMasterAdmin();
    }

    function isMeetingManager() {
      let role = getUserData().get('role', 'member');
      return role == 'chairperson' || role == 'secretary' || isMasterAdmin();
    }

    function isOwner(id) {
      return isSignedIn() && (request.auth.uid == id || (request.auth.token.email != null && request.auth.token.email == id));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Validations
    function isValidUser(data) {
      return data.get('position', 'staff') in ['admin', 'principal', 'vice_principal', 'teacher', 'staff'] &&
             data.get('role', 'member') in ['chairperson', 'secretary', 'member'];
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['title', 'scheduledAt', 'status', 'createdBy']);
    }

    // Rules
    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || isOwner(userId));
      allow create: if isMasterAdmin() || isAdmin();
      allow update: if isMasterAdmin() || isAdmin() || 
                   (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phoneNumber', 'uid']));
      allow delete: if isMasterAdmin() || isAdmin();
    }

    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow create: if isMeetingManager() && isValidMeeting(request.resource.data);
      allow update: if isMeetingManager() && isValidMeeting(request.resource.data);
      allow delete: if isMeetingManager();

      match /attendance/{userId} {
        allow read: if isSignedIn();
        allow write: if isManagement() || isOwner(userId);
      }

      match /opinions/{opinionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
      }

      match /tasks/{taskId} {
        allow read: if isSignedIn();
        allow write: if isManagement();
      }

      match /documents/{docId} {
        allow read: if isSignedIn();
        allow create: if isManagement();
        allow delete: if isManagement();
      }

      match /personalNotes/{ownerId} {
        allow read, write: if isOwner(ownerId) || isMasterAdmin();
      }
    }
  }
}
